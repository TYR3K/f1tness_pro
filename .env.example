OPENAI_API_KEY=
BOT_TOKEN=
DATABASE_URL=sqlite:///./app.db
ALLOW_INSECURE_AUTH=0
# DEBUG_AI=1 — показывать «сырой» ответ модели в приложении и в тексте ошибки
# (удобно для отладки распознавания). На проде держите 0.
DEBUG_AI=0
# OPENAI_MODEL — можно переопределить модель (по умолчанию gpt-4o).
# OPENAI_MODEL=gpt-4o
# --- Push-уведомления (через бота) ---
# APP_TZ — часовой пояс для времени напоминаний (по умолчанию Europe/Moscow).
APP_TZ=Europe/Moscow
# ENABLE_SCHEDULER=0 полностью выключает планировщик уведомлений (по умолчанию включён,
# если задан BOT_TOKEN). Уведомления шлёт тот же BOT_TOKEN, что и для авторизации.
# ENABLE_SCHEDULER=1

# === Подписка и доступ (Этап 1) ===
# OWNER_ID — числовой Telegram ID владельца (@TYREK223). У него вечный премиум,
# и только он может выполнять /givepro и /revokepro. Как узнать id — см. README.
OWNER_ID=
# Цены тарифов в Telegram Stars (НЕ хардкод — меняются здесь одним числом).
# ~500 ₽ на запуске ≈ 250 ⭐, но курс плавающий — перепроверьте перед запуском.
PRICE_MONTHLY_STARS=250
PRICE_YEARLY_STARS=2000
PRICE_LIFETIME_STARS=4000
# Длительность подписок в днях (lifetime — бессрочно).
SUBSCRIPTION_MONTHLY_DAYS=30
SUBSCRIPTION_YEARLY_DAYS=365
# Сколько бесплатных сканирований еды в сутки для free-пользователя.
FREE_SCAN_LIMIT=3
# Секрет вебхука Telegram — случайная строка; та же передаётся в setWebhook.
TELEGRAM_WEBHOOK_SECRET=
# Username бота без "@" (для ссылок), напр. my_calorie_ai_bot.
BOT_USERNAME=
# --- Tribute (второй способ оплаты) — заполняется по инструкции TRIBUTE.md ---
# Секрет для проверки подлинности вебхука Tribute.
TRIBUTE_WEBHOOK_SECRET=
# Ссылка на оплату Tribute (создаётся в Tribute). Пусто — кнопка Tribute скрыта.
TRIBUTE_URL=
