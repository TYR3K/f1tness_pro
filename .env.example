OPENAI_API_KEY=
BOT_TOKEN=
DATABASE_URL=sqlite:///./app.db
ALLOW_INSECURE_AUTH=0
# DEBUG_AI=1 — показывать «сырой» ответ модели в приложении и в тексте ошибки
# (удобно для отладки распознавания). На проде держите 0.
DEBUG_AI=0
# OPENAI_MODEL — можно переопределить модель (по умолчанию gpt-4o).
# OPENAI_MODEL=gpt-4o
# --- Push-уведомления (через бота) ---
# APP_TZ — часовой пояс для времени напоминаний (по умолчанию Europe/Moscow).
APP_TZ=Europe/Moscow
# ENABLE_SCHEDULER=0 полностью выключает планировщик уведомлений (по умолчанию включён,
# если задан BOT_TOKEN). Уведомления шлёт тот же BOT_TOKEN, что и для авторизации.
# ENABLE_SCHEDULER=1
